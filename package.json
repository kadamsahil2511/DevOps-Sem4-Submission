{
  "name": "tradenet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "services/api"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "npm run dev --workspace @tradenet/api",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc -b && vite build",
    "build:api": "npm run build --workspace @tradenet/api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "seed": "npm run seed --workspace @tradenet/api",
    "seed:dev": "npm run seed:dev --workspace @tradenet/api",
    "lint": "eslint .",
    "test": "npm test --workspace @tradenet/api",
    "preview": "vite preview",
    "inventory-aws": "bash scripts/aws-inventory.sh"
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
